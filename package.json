{
  "name": "jira-client",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8080 & (timeout /t 4 /nobreak >nul && start http://localhost:8080)",
    "clean": "node -e \"const fs=require('fs');try{fs.rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev:clean": "npm run clean && next dev -p 8080",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 8080",
    "lint": "next lint"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/jsonwebtoken": "^9.0.10",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "imapflow": "^1.3.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.378.0",
    "next": "^14.2.0",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.4.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0"
  }
}
